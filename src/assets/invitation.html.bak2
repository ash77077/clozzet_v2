					                                   <!--ts1767634273605ts-->
						<script>  (function () {
              const settingArr = [{
                block: '#rec1269730411, #rec1264695121, #rec1264688261, #rec1760680951',
                zero: 'mycart010',
                zIndex: '1000',
              }];

              function n_ready(t) {
                "loading" != document.readyState ? t() : document.addEventListener ? document.addEventListener("DOMContentLoaded", t) : document.attachEvent("onreadystatechange", function () {
                  "loading" != document.readyState && t()
                })
              };n_ready(function () {
                settingArr.forEach(item => {
                  if (item.block !== '') {
                    document.querySelectorAll(item.block).forEach(el => {
                      el.style.zIndex = Number(item.zIndex);
                      el.style.position = 'relative';
                    });
                  }
                  if (item.zero !== '') {
                    const selector = item.zero.split(',').map(el => '.' + el).join(',');
                    document.querySelectorAll(selector).forEach(el => {
                      el.style.zIndex = Number(item.zIndex);
                    });
                  }
                })
              });
            })(); </script> <!-- nominify end --> </div>
