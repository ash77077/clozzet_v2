                const timerClass = "tn-elem__16156733111772800072347000005";
                const checkInterval = 100;
                const maxAttempts = 100;

                function waitForTimerElements() {
                  let attempts = 0;
                  const waitInterval = setInterval(function () {
                    const timerElements = document.querySelectorAll('.' + timerClass + ' .tn-atom');
                    attempts++;
                    if (timerElements.length > 0) {
                      clearInterval(waitInterval);
                      initializeTimer(timerElements);
                    } else if (attempts >= maxAttempts) {
                      clearInterval(waitInterval);
                    }
                  }, checkInterval);
                }

                function initializeTimer(timerElements) {
                  const dateArray = dateStrings.split(',').map(function (dateString) {
                    const parts = dateString.trim().split(' ');
                    const dateParts = parts[0].split('-');
                    const timeParts = parts[1].split(':');
                    return new Date(dateParts[0], dateParts[1] - 1, dateParts[2], timeParts[0], timeParts[1]);
                  });
                  let currentEndDateIndex = 0;
                  let targetEndTime;
                  let timerInterval;
                  let isTimerStopped = false;

                  function checkAllDatesExpired() {
                    const now = new Date().getTime();
                    for (let i = 0; i < dateArray.length; i++) {
                      if (dateArray[i].getTime() > now) {
                        return false;
                      }
                    }
                    return true;
                  }

                  function updateTimer() {
                    const now = new Date().getTime();
                    const timeLeft = targetEndTime - now;
                    if ((now >= dateArray[currentEndDateIndex].getTime()) && !isTimerStopped) {
                      clearInterval(timerInterval);
                      currentEndDateIndex++;
                      if (currentEndDateIndex >= dateArray.length) {
                        isTimerStopped = true;
                        timerElements.forEach(function (timerElement) {
                          timerElement.textContent = expiredMessage;
                        });
                        return;
                      }
                      resetTimer();
                    } else {
                      const remainingDays = Math.floor(timeLeft / (1000 * 60 * 60 * 24));
                      const remainingHours = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                      const remainingMinutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
                      const remainingSeconds = Math.floor((timeLeft % (1000 * 60)) / 1000);
                      const timerParts = [];
                      if (showDays) timerParts.push(padNumber(remainingDays));
                      if (showHours) timerParts.push(padNumber(remainingHours));
                      if (showMinutes) timerParts.push(padNumber(remainingMinutes));
                      if (showSeconds) timerParts.push(padNumber(remainingSeconds));
                      const formattedTimer = timerParts.join(':');
                      timerElements.forEach(function (timerElement) {
                        timerElement.textContent = formattedTimer;
                      });
                    }
                  }

                  function padNumber(number) {
                    return number < 10 ? '0' + number : number;
                  }

                  function resetTimer() {
                    if (checkAllDatesExpired()) {
                      isTimerStopped = true;
                      timerElements.forEach(function (timerElement) {
                        timerElement.textContent = expiredMessage;
