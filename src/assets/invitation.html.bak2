	<div id="rec2376094331" class="r t-rec" style=" " data-animationappear="off" data-record-type="131"> <!-- T123 -->
		<div class="t123">
			<div class="t-container_100 ">
				<div class="t-width t-width_100 "> <!-- nominify begin -->
					<script>
            // Функция для определения, видим ли элемент на экране
            function isInViewport(element) {
              const rect = element.getBoundingClientRect();
              return (
                rect.top < window.innerHeight &&
                rect.bottom > 0
              );
            }

            document.addEventListener('DOMContentLoaded', function () {
              const players = document.querySelectorAll('.video-player');

              // Проверка поддержки Intersection Observer
              if ('IntersectionObserver' in window) {
                const observer = new IntersectionObserver(function (entries, obs) {
                  entries.forEach(entry => {
                    const video = entry.target.querySelector('video');
                    if (!video) return;

                    if (entry.isIntersecting) {
                      video.play();
                    } else {
                      video.pause();
                    }
                  });
                }, {
                  threshold: 0.2 // запускать при видимости 20% блока
                });

                players.forEach(player => observer.observe(player));
              } else {
                // На крайний случай - без IntersectionObserver
                function checkVideos() {
                  players.forEach(player => {
                    const video = player.querySelector('video');
                    if (!video) return;
                    if (isInViewport(player)) {
                      video.play();
                    } else {
                      video.pause();
                    }
                  });
                }

                window.addEventListener('scroll', checkVideos);
                window.addEventListener('resize', checkVideos);
                checkVideos();
              }
            });
					</script> <!-- nominify end --> </div>
			</div>
		</div>
